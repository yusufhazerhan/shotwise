{
  "name": "@shotwise/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured' && exit 0",
    "test": "echo 'no tests' && exit 0",
    "build": "echo 'source-consumed, no build' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop"
  },
  "dependencies": {
    "@shotwise/types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.6.3"
  }
}
