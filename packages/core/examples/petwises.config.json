      "accent": "what"
    },
    {
      "source": "progress.png",
      "out": "09_progress.png",
      "title": "See real progress, every step",
      "accent": "real"
    },
    {
      "source": "profile.png",
      "out": "10_profile.png",
      "title": "All your pets.\nOne home.",
      "accent": "One home"
    }
  ]
