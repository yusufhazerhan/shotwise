{
  "name": "@shotwise/core",
  "version": "0.0.1",
  "description": "Native SVG and Sharp renderer for App Store, Google Play, iPhone, Android, iPad, and localized marketing screenshots.",
  "keywords": [
    "app-store-screenshots",
    "google-play-screenshots",
    "screenshot-renderer",
    "sharp",
    "svg",
    "iphone-mockup",
    "android-mockup",
    "ipad-screenshots",
    "aso"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx examples/cli.ts"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yargs": "^17.7.2",
    "@types/yargs": "^17.0.32"
  },
  "engines": {
    "node": ">=20"
  }
}
