# ──────────────────────────────────────────────────────────────────────────────
# Shotwise — Environment Variables
# Copy to `.env.local` for local dev. Production: inject via docker-compose env_file.
# ──────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (local: docker compose postgres)
DATABASE_URL=postgres://shotwise:shotwise@localhost:5432/shotwise

# Better-Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-secret-change-me-in-prod-please-32chars
BETTER_AUTH_URL=http://localhost:3000

# OAuth (opsiyonel — boş bırakılırsa Google butonu gizlenir)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend — magic link gönderimi)
# https://resend.com — free tier 100 email/day, 3000/month
RESEND_API_KEY=
RESEND_FROM_EMAIL=Shotwise <noreply@shotwise.app>

# AI (Google Gemini)
# https://aistudio.google.com — free tier yeterli
GEMINI_API_KEY=

# Storage (S3-compatible — MinIO local, R2/Backblaze/AWS S3 prod)
# Local MinIO defaults (docker-compose):
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_RAW=shotwise-raw
S3_BUCKET_EXPORTS=shotwise-exports
S3_FORCE_PATH_STYLE=true
# For signed URLs that clients can hit directly:
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Payment (Paddle)
# https://www.paddle.com — sandbox: https://sandbox-vendors.paddle.com
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_VENDOR_ID=
# Create products in Paddle dashboard, paste price IDs:
PADDLE_PRICE_STARTER=pri_starter_4_99
PADDLE_PRICE_TOPUP=pri_topup_2_99
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Credit economics (override defaults if needed)
CREDITS_SIGNUP_TRIAL=5
CREDITS_STARTER_PACK=100
CREDITS_TOPUP=50
CREDITS_MONTHLY_REFILL=20

# Cron secret (used by /api/cron/* endpoints)
CRON_SECRET=dev-cron-secret-change-me

# Observability (opsiyonel)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Export job
EXPORT_TIMEOUT_MS=300000
EXPORT_TTL_HOURS=24
